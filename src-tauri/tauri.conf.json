{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "docxlite",
  "version": "0.1.0",
  "identifier": "com.maudev.docxlite",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "python -m http.server 8080 -d public",
    "beforeBuildCommand": "node build.js"
  },
  "app": {
    "windows": [
      {
        "title": "DocxLite",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob:; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
